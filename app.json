{
  "expo": {
    "name": "ShotMat",
    "slug": "shotmat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shotmat.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "ShotMat kamera erişimi gerektirmez.",
        "NSPhotoLibraryUsageDescription": "Parti sonuçlarınızı kaydetmek için fotoğraf galerisine erişim gerekebilir.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.shotmat.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-font",
      "react-native-iap",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-7264754027467588~4008160204",
          "androidAppId": "ca-app-pub-3940256099942544~3347511713"
        }
      ]
    ],
    "extra": {
      "admobInterstitialIdIos": "ca-app-pub-7264754027467588/3707374938",
      "admobInterstitialIdAndroid": "",
      "eas": {
        "projectId": "cf8f9448-d596-483b-aca4-ca734c6da81c"
      }
    }
  }
}
